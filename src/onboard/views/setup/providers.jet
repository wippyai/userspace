{{ extends "onboard/step" }}

{{ block title() }}AI Setup{{ end }}

{{ block stepContent() }}
<div class="max-w-4xl mx-auto" x-data="providersStep()">

    <!-- Header -->
    <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-surface-900 dark:text-surface-100 mb-4">
            Connect Your AI
        </h1>
        <p class="text-xl text-surface-700 dark:text-surface-300 max-w-3xl mx-auto leading-relaxed">
            Configure your AI providers to get started with Wippy.
        </p>
    </div>

    <!-- Provider Options -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

        <!-- OpenRouter (Required) -->
        <div class="bg-white dark:bg-surface-800 rounded-2xl border border-surface-200 dark:border-surface-700 p-4">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center">
                    <iconify-icon icon="tabler:world" class="text-white" width="20" height="20"></iconify-icon>
                </div>
                <div>
                    <h3 class="font-bold text-surface-900 dark:text-surface-100">
                        OpenRouter
                        <span class="text-xs bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 px-1.5 py-0.5 rounded ml-2">Required</span>
                    </h3>
                    <p class="text-xs text-green-600 dark:text-green-400 font-medium">Access to Claude 4, GPT-5, Gemini & More</p>
                </div>
            </div>

            <input
                    type="password"
                    x-model="keys.openrouter"
                    placeholder="sk-or-v1-..."
                    class="w-full px-4 py-3 border border-surface-300 dark:border-surface-600 rounded-xl bg-white dark:bg-surface-800 text-surface-900 dark:text-surface-100 focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors mb-3"
                    required>

            <div class="space-y-2 text-sm">
                <div class="flex items-center gap-2 text-surface-600 dark:text-surface-400">
                    <iconify-icon icon="tabler:check" class="text-green-500" width="16" height="16"></iconify-icon>
                    <span>Claude 4, GPT-5, Gemini, DeepSeek</span>
                </div>
                <div class="flex items-center gap-2 text-surface-600 dark:text-surface-400">
                    <iconify-icon icon="tabler:check" class="text-green-500" width="16" height="16"></iconify-icon>
                    <span>Single API for multiple providers</span>
                </div>
                <div class="flex items-center gap-2 text-surface-600 dark:text-surface-400">
                    <iconify-icon icon="tabler:check" class="text-green-500" width="16" height="16"></iconify-icon>
                    <span>Competitive pricing & rate limits</span>
                </div>
                <div class="mt-3">
                    <a href="https://openrouter.ai/keys" target="_blank" class="text-green-600 dark:text-green-400 hover:underline text-sm">
                        Get your OpenRouter API key →
                    </a>
                </div>
            </div>
        </div>

        <!-- OpenAI (Optional) -->
        <div class="bg-white dark:bg-surface-800 rounded-2xl border border-surface-200 dark:border-surface-700 p-4">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center">
                    <iconify-icon icon="tabler:robot" class="text-white" width="20" height="20"></iconify-icon>
                </div>
                <div>
                    <h3 class="font-bold text-surface-900 dark:text-surface-100">
                        OpenAI
                        <span class="text-xs bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-1.5 py-0.5 rounded ml-2">Optional</span>
                    </h3>
                    <p class="text-xs text-blue-600 dark:text-blue-400 font-medium">Direct Access + Embeddings</p>
                </div>
            </div>

            <input
                    type="password"
                    x-model="keys.openai"
                    placeholder="sk-..."
                    class="w-full px-4 py-3 border border-surface-300 dark:border-surface-600 rounded-xl bg-white dark:bg-surface-800 text-surface-900 dark:text-surface-100 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors mb-3">

            <div class="space-y-2 text-sm">
                <div class="flex items-center gap-2 text-surface-600 dark:text-surface-400">
                    <iconify-icon icon="tabler:check" class="text-blue-500" width="16" height="16"></iconify-icon>
                    <span>Direct OpenAI access (faster)</span>
                </div>
                <div class="flex items-center gap-2 text-surface-600 dark:text-surface-400">
                    <iconify-icon icon="tabler:check" class="text-blue-500" width="16" height="16"></iconify-icon>
                    <span>Embedding models for knowledge base</span>
                </div>
                <div class="mt-3">
                    <a href="https://platform.openai.com/api-keys" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline text-sm">
                        Get your OpenAI API key →
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Setup Button -->
    <div x-show="canSetup()" x-transition class="text-center mb-8">
        <button @click="setupProviders()" :disabled="isSettingUp"
                class="px-8 py-4 bg-primary-600 hover:bg-primary-700 disabled:bg-surface-300 disabled:dark:bg-surface-700 text-white font-semibold rounded-xl transition-colors disabled:cursor-not-allowed flex items-center gap-3 mx-auto">
            <iconify-icon :icon="isSettingUp ? 'tabler:loader-2' : 'tabler:rocket'" :class="{'animate-spin': isSettingUp}" width="20" height="20"></iconify-icon>
            <span x-text="isSettingUp ? 'Setting Up...' : 'Setup AI Providers'"></span>
        </button>
    </div>

    <!-- Error Display -->
    <div x-show="setupError" x-transition class="bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-800 rounded-xl p-4 mb-6">
        <div class="flex items-start gap-3">
            <iconify-icon icon="tabler:alert-circle" class="text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5" width="20" height="20"></iconify-icon>
            <div class="text-sm text-red-800 dark:text-red-200" x-text="setupError"></div>
        </div>
    </div>

    <!-- Success Display -->
    <div x-show="setupComplete && setupSuccess" x-transition class="bg-green-50 dark:bg-green-950/20 border border-green-200 dark:border-green-800 rounded-xl p-6 mb-6">
        <div class="flex items-center justify-center gap-3">
            <iconify-icon icon="tabler:check-circle" class="text-green-600 dark:text-green-400" width="24" height="24"></iconify-icon>
            <h3 class="text-lg font-bold text-green-800 dark:text-green-200">AI Providers Connected Successfully!</h3>
        </div>
        <p class="text-center text-sm text-green-700 dark:text-green-300 mt-2">
            You're ready to start using Wippy with your AI models.
        </p>
    </div>

    <!-- Failed Setup Display -->
    <div x-show="setupComplete && !setupSuccess" x-transition class="bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-800 rounded-xl p-6 mb-6">
        <div class="flex items-start gap-3 mb-4">
            <iconify-icon icon="tabler:alert-circle" class="text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5" width="24" height="24"></iconify-icon>
            <div>
                <h3 class="text-lg font-bold text-red-800 dark:text-red-200 mb-2">Setup Failed</h3>
                <div class="space-y-1">
                    <template x-for="item in setupSummary">
                        <div class="text-sm text-red-700 dark:text-red-300" x-text="item"></div>
                    </template>
                </div>
            </div>
        </div>
        <p class="text-sm text-red-700 dark:text-red-300">
            Please check your API keys and try again. No configuration changes were saved.
        </p>
    </div>

    <!-- No Keys State -->
    <div x-show="!canSetup() && !isSettingUp && !setupComplete" class="text-center py-12">
        <iconify-icon icon="tabler:key" class="text-surface-400 dark:text-surface-600 mb-4" width="64" height="64"></iconify-icon>
        <h3 class="text-xl font-semibold text-surface-900 dark:text-surface-100 mb-3">Add OpenRouter API Key to Continue</h3>
        <p class="text-surface-600 dark:text-surface-400 max-w-2xl mx-auto text-sm leading-relaxed">
            OpenRouter provides access to Claude 4, GPT-5, Gemini, and other leading AI models through a single API. Adding an OpenAI key is optional but recommended for embedding support and enhanced features.
        </p>
    </div>

    <!-- Footer Information -->
    <div class="text-center mt-8">
        <div class="bg-surface-50 dark:bg-surface-900 rounded-xl p-4">
            <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed mb-3">
                Need Anthropic direct access or local models? Additional providers like Anthropic, Ollama, LM Studio, and LocalAI can be configured later through the <span class="font-medium text-surface-700 dark:text-surface-300">Registry</span> or <span class="font-medium text-surface-700 dark:text-surface-300">Maker Agent</span>.
            </p>
            <p class="text-sm text-surface-500 dark:text-surface-500">
                API keys are stored securely and never shared with third parties
            </p>
        </div>
    </div>
</div>

<script>
    function providersStep() {
        return {
            keys: {
                openrouter: '',
                openai: ''
            },
            isSettingUp: false,
            setupError: null,
            setupComplete: false,
            setupSuccess: false,
            setupSummary: [],
            setupStats: null,
            api: null,

            async init() {
                this.api = await $W.api();
            },

            canSetup() {
                return this.keys.openrouter && this.keys.openrouter.length > 0;
            },

            async setupProviders() {
                this.isSettingUp = true;
                this.setupError = null;
                this.setupComplete = false;
                this.setupSuccess = false;

                try {
                    const response = await this.api.post('/api/v1/onboard/setup/providers', this.keys);
                    const data = response.data;

                    this.setupComplete = true;
                    this.setupSuccess = data.success;
                    this.setupSummary = data.summary || [];
                    this.setupStats = data.stats;

                } catch (error) {
                    this.setupComplete = true;
                    this.setupSuccess = false;

                    if (error.response?.data?.summary) {
                        this.setupSummary = error.response.data.summary;
                    } else {
                        this.setupError = error.response?.data?.error || error.message || 'Connection failed';
                    }
                }

                this.isSettingUp = false;
            }
        }
    }
</script>
{{ end }}