{{ extends "onboard/step" }}

{{ block title() }}Connect to OpenRouter{{ end }}

{{ block stepContent() }}
<div class="max-w-3xl mx-auto" x-data="openRouterStep()">

    <!-- Header -->
    <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-surface-900 dark:text-surface-100 mb-6">
            Connect to OpenRouter
        </h1>
        <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto">
            What we use to connect to leading large language models and allows you to switch between different models for different tasks.
        </p>
    </div>

    <!-- OpenRouter Configuration -->
    <div class="bg-white dark:bg-surface-800 rounded-2xl border border-surface-200 dark:border-surface-700 p-8 mb-8">
        <div class="flex items-center gap-4 mb-8">
            <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center">
                <iconify-icon icon="tabler:world" class="text-white" width="32" height="32"></iconify-icon>
            </div>
            <div>
                <h3 class="text-2xl font-bold text-surface-900 dark:text-surface-100 mb-2">OpenRouter</h3>
                <p class="text-surface-600 dark:text-surface-400 text-lg">Connect to leading AI models and switch between them</p>
            </div>
        </div>

        <input
                type="password"
                x-model="apiKey"
                placeholder="sk-or-v1-..."
                class="w-full px-6 py-5 border border-surface-300 dark:border-surface-600 rounded-xl bg-white dark:bg-surface-800 text-surface-900 dark:text-surface-100 focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors mb-8 text-lg"
                required>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="flex items-center gap-3 text-surface-700 dark:text-surface-300">
                <iconify-icon icon="tabler:check" class="text-green-500 flex-shrink-0" width="20" height="20"></iconify-icon>
                <span class="text-lg">Claude 4, GPT-5, Gemini, DeepSeek</span>
            </div>
            <div class="flex items-center gap-3 text-surface-700 dark:text-surface-300">
                <iconify-icon icon="tabler:check" class="text-green-500 flex-shrink-0" width="20" height="20"></iconify-icon>
                <span class="text-lg">Single API for multiple providers</span>
            </div>
        </div>

        <a href="https://openrouter.ai/keys" target="_blank" class="inline-flex items-center gap-3 text-green-600 dark:text-green-400 hover:underline font-medium text-lg">
            <span>Get your OpenRouter API key</span>
            <iconify-icon icon="tabler:external-link" width="20" height="20"></iconify-icon>
        </a>
    </div>

    <!-- Setup Button -->
    <div x-show="canSetup()" x-transition class="text-center mb-8">
        <button @click="setupOpenRouter()" :disabled="isSettingUp"
                class="px-10 py-5 bg-primary-600 hover:bg-primary-700 disabled:bg-surface-300 disabled:dark:bg-surface-700 text-white font-semibold rounded-xl transition-colors disabled:cursor-not-allowed flex items-center gap-3 mx-auto text-lg">
            <iconify-icon :icon="isSettingUp ? 'tabler:loader-2' : 'tabler:rocket'" :class="{'animate-spin': isSettingUp}" width="24" height="24"></iconify-icon>
            <span x-text="isSettingUp ? 'Connecting...' : 'Connect OpenRouter'"></span>
        </button>
    </div>

    <!-- Error Display -->
    <div x-show="setupError" x-transition class="bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-800 rounded-xl p-4 mb-6">
        <div class="flex items-start gap-3">
            <iconify-icon icon="tabler:alert-circle" class="text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5" width="20" height="20"></iconify-icon>
            <div class="text-sm text-red-800 dark:text-red-200" x-text="setupError"></div>
        </div>
    </div>

    <!-- Success Display -->
    <div x-show="setupComplete && setupSuccess" x-transition class="bg-green-50 dark:bg-green-950/20 border border-green-200 dark:border-green-800 rounded-xl p-6 mb-6">
        <div class="flex items-center justify-center gap-3">
            <iconify-icon icon="tabler:check-circle" class="text-green-600 dark:text-green-400" width="24" height="24"></iconify-icon>
            <h3 class="text-lg font-bold text-green-800 dark:text-green-200">OpenRouter Connected Successfully!</h3>
        </div>
        <p class="text-center text-sm text-green-700 dark:text-green-300 mt-2">
            You now have access to Claude 4, GPT-5, Gemini, and other leading AI models.
        </p>
    </div>

    <!-- Failed Setup Display -->
    <div x-show="setupComplete && !setupSuccess" x-transition class="bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-800 rounded-xl p-6 mb-6">
        <div class="flex items-start gap-3 mb-4">
            <iconify-icon icon="tabler:alert-circle" class="text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5" width="24" height="24"></iconify-icon>
            <div>
                <h3 class="text-lg font-bold text-red-800 dark:text-red-200 mb-2">Connection Failed</h3>
                <div class="space-y-1">
                    <template x-for="item in setupSummary">
                        <div class="text-sm text-red-700 dark:text-red-300" x-text="item"></div>
                    </template>
                </div>
            </div>
        </div>
        <p class="text-sm text-red-700 dark:text-red-300">
            Please check your API key and try again.
        </p>
    </div>

    <!-- No Key State -->
    <div x-show="!canSetup() && !isSettingUp && !setupComplete" class="text-center py-12">
        <iconify-icon icon="tabler:key" class="text-surface-400 dark:text-surface-600 mb-4" width="64" height="64"></iconify-icon>
        <h3 class="text-xl font-semibold text-surface-900 dark:text-surface-100 mb-3">Enter your OpenRouter API key to continue</h3>
        <p class="text-surface-600 dark:text-surface-400 max-w-2xl mx-auto text-sm leading-relaxed">
            OpenRouter provides access to the best AI models through a single, reliable API with competitive pricing.
        </p>
    </div>

    <!-- Footer Information -->
    <div class="text-center mt-8">
        <div class="bg-surface-50 dark:bg-surface-900 rounded-xl p-4">
            <p class="text-sm text-surface-500 dark:text-surface-500">
                Your API key is stored securely and never shared with third parties
            </p>
        </div>
    </div>
</div>

<script>
    function openRouterStep() {
        return {
            apiKey: '',
            isSettingUp: false,
            setupError: null,
            setupComplete: false,
            setupSuccess: false,
            setupSummary: [],
            api: null,

            async init() {
                this.api = await $W.api();
            },

            canSetup() {
                return this.apiKey && this.apiKey.length > 0;
            },

            async setupOpenRouter() {
                this.isSettingUp = true;
                this.setupError = null;
                this.setupComplete = false;
                this.setupSuccess = false;

                try {
                    const response = await this.api.post('/api/v1/onboard/setup/openrouter', {
                        api_key: this.apiKey
                    });
                    const data = response.data;

                    this.setupComplete = true;
                    this.setupSuccess = data.success;
                    this.setupSummary = data.summary || [];

                } catch (error) {
                    this.setupComplete = true;
                    this.setupSuccess = false;

                    if (error.response?.data?.summary) {
                        this.setupSummary = error.response.data.summary;
                    } else {
                        this.setupError = error.response?.data?.error || error.message || 'Connection failed';
                    }
                }

                this.isSettingUp = false;
            }
        }
    }
</script>
{{ end }}