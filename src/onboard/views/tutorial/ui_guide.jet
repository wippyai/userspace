{{ extends "onboard/step" }}

{{ block title() }}Wippy UI Interface Guide{{ end }}

{{ block stepContent() }}
<div class="max-w-6xl mx-auto" x-data="uiTutorialApp()">

    <!-- Header -->
    <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-surface-900 dark:text-surface-100 mb-4">
            Wippy Interface Guide
        </h1>
        <p class="text-lg text-surface-700 dark:text-surface-300 max-w-3xl mx-auto leading-relaxed">
            Learn how to navigate and use Wippy's interface effectively.
        </p>
    </div>

    <!-- Navigation and Chat Access -->
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 mb-6 p-6">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-100 mb-4">Navigation and Chat Access</h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-center">
            <div>
                <img src="/tutorial_images/right_panel.png" alt="Chat panel activation" class="w-full max-w-xs mx-auto rounded-lg border border-surface-200 dark:border-surface-700" />
            </div>

            <div class="space-y-4">
                <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-4">
                    <h4 class="font-semibold text-surface-900 dark:text-surface-100 mb-3">Two Ways to Access Chat</h4>
                    <div class="space-y-2 text-sm">
                        <div class="flex items-center gap-2">
                            <iconify-icon icon="tabler:message-circle" class="text-blue-500" width="16" height="16"></iconify-icon>
                            <span class="text-surface-700 dark:text-surface-300">Click "Chat" in bottom-left corner</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <iconify-icon icon="tabler:cursor-text" class="text-blue-500" width="16" height="16"></iconify-icon>
                            <span class="text-surface-700 dark:text-surface-300">Mouse over the right edge of screen</span>
                        </div>
                    </div>
                </div>

                <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-4">
                    <h4 class="font-semibold text-surface-900 dark:text-surface-100 mb-3">Navigation Sections</h4>
                    <p class="text-sm text-surface-600 dark:text-surface-400 mb-3">Navigate by opening the left panel to access different areas of Wippy:</p>
                    <div class="grid grid-cols-1 gap-1 text-sm">
                        <div class="text-surface-700 dark:text-surface-300">• My Home - Dashboard</div>
                        <div class="text-surface-700 dark:text-surface-300">• Projects - Your work</div>
                        <div class="text-surface-700 dark:text-surface-300">• Knowledge Bases - AI data</div>
                        <div class="text-surface-700 dark:text-surface-300">• Connections - Integrations</div>
                        <div class="text-surface-700 dark:text-surface-300">• My Uploads - File management</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- File Handling -->
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 mb-6 p-6">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-100 mb-4">Working with Files</h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-center">
            <div>
                <img src="/tutorial_images/chat_footer.png" alt="File upload interface" class="w-full rounded-lg border border-surface-200 dark:border-surface-700" />
            </div>

            <div class="grid grid-cols-1 gap-4">
                <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-4">
                    <h4 class="font-semibold text-surface-900 dark:text-surface-100 mb-2">Upload New Files</h4>
                    <div class="space-y-1 text-sm text-surface-700 dark:text-surface-300">
                        <div>• Click "Upload" button in chat</div>
                        <div>• Drag and drop files directly into chat</div>
                        <div>• Uploaded files appear in "My Uploads" section</div>
                    </div>
                </div>
                <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-4">
                    <h4 class="font-semibold text-surface-900 dark:text-surface-100 mb-2">Use Existing Files</h4>
                    <div class="space-y-1 text-sm text-surface-700 dark:text-surface-300">
                        <div>• Click "Browse" to see uploaded files</div>
                        <div>• Access files from "My Uploads" navigation</div>
                        <div>• Reference files in conversations</div>
                        <div>• Files persist across sessions</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Session and Model Controls -->
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 mb-6 p-6">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-100 mb-4">Sessions and AI Models</h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-center">
            <div>
                <img src="/tutorial_images/chat_header.png" alt="Session controls" class="w-full rounded-lg border border-surface-200 dark:border-surface-700" />
            </div>

            <div class="grid grid-cols-1 gap-4">
                <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-4">
                    <h4 class="font-semibold text-surface-900 dark:text-surface-100 mb-2">Session Management</h4>
                    <div class="space-y-1 text-sm text-surface-700 dark:text-surface-300">
                        <div>• Switch between conversation sessions</div>
                        <div>• Sessions preserve context and history</div>
                        <div>• Continue where you left off</div>
                    </div>
                </div>
                <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-4">
                    <h4 class="font-semibold text-surface-900 dark:text-surface-100 mb-2">AI Model Selection</h4>
                    <div class="space-y-1 text-sm text-surface-700 dark:text-surface-300">
                        <div>• Choose from GPT-4.1, Claude, Gemini</div>
                        <div>• Switch agents (left dropdown)</div>
                        <div>• Different models for different tasks</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- System Controls and Checkpoints -->
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 mb-6 p-6">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-100 mb-4">System Controls and Checkpoints</h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-center">
            <div>
                <img src="/tutorial_images/bottom_panel.png" alt="System controls" class="w-full rounded-lg border border-surface-200 dark:border-surface-700" />
            </div>

            <div class="grid grid-cols-1 gap-4">
                <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-4">
                    <h4 class="font-semibold text-surface-900 dark:text-surface-100 mb-2">Version Control</h4>
                    <div class="space-y-1 text-sm text-surface-700 dark:text-surface-300">
                        <div>• Undo/redo agent changes</div>
                        <div>• Track system modifications</div>
                        <div>• Rollback between versions</div>
                    </div>
                </div>

                <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-4">
                    <h4 class="font-semibold text-surface-900 dark:text-surface-100 mb-2">Save Your Progress</h4>
                    <div class="space-y-1 text-sm text-surface-700 dark:text-surface-300">
                        <div>• Download: Save current state</div>
                        <div>• Upload: Load saved checkpoint</div>
                        <div>• Create backup snapshots</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Advanced Configuration -->
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 mb-6 p-6">
        <h2 class="text-xl font-bold text-surface-900 dark:text-surface-100 mb-4">Advanced Configuration</h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-center">
            <div>
                <img src="/tutorial_images/keeper_navigation.png" alt="Configuration menu" class="w-full max-w-sm mx-auto rounded-lg border border-surface-200 dark:border-surface-700" />
            </div>

            <div class="space-y-4">
                <div class="bg-amber-50 dark:bg-amber-950/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4">
                    <div class="flex items-center gap-2 mb-2">
                        <iconify-icon icon="tabler:settings" class="text-amber-600 dark:text-amber-400" width="16" height="16"></iconify-icon>
                        <h4 class="font-semibold text-surface-900 dark:text-surface-100">When to Use Advanced Settings</h4>
                    </div>
                    <p class="text-sm text-surface-700 dark:text-surface-300">
                        Click the gear icon when you need to configure system internals, view AI usage statistics, or access advanced features beyond normal chat interactions.
                    </p>
                </div>

                <div class="grid grid-cols-2 gap-3 text-sm">
                    <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-3">
                        <h5 class="font-medium text-surface-900 dark:text-surface-100 mb-1">All Agents</h5>
                        <p class="text-surface-600 dark:text-surface-400">Configure AI assistants</p>
                    </div>
                    <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-3">
                        <h5 class="font-medium text-surface-900 dark:text-surface-100 mb-1">Token Usage</h5>
                        <p class="text-surface-600 dark:text-surface-400">Monitor AI costs</p>
                    </div>
                    <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-3">
                        <h5 class="font-medium text-surface-900 dark:text-surface-100 mb-1">Environment</h5>
                        <p class="text-surface-600 dark:text-surface-400">System variables</p>
                    </div>
                    <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-3">
                        <h5 class="font-medium text-surface-900 dark:text-surface-100 mb-1">Sessions</h5>
                        <p class="text-surface-600 dark:text-surface-400">Active conversations</p>
                    </div>
                    <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-3">
                        <h5 class="font-medium text-surface-900 dark:text-surface-100 mb-1">Workflows</h5>
                        <p class="text-surface-600 dark:text-surface-400">Automated processes</p>
                    </div>
                    <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-3">
                        <h5 class="font-medium text-surface-900 dark:text-surface-100 mb-1">Workspaces</h5>
                        <p class="text-surface-600 dark:text-surface-400">Collaborative areas</p>
                    </div>
                    <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-3">
                        <h5 class="font-medium text-surface-900 dark:text-surface-100 mb-1">Schedules</h5>
                        <p class="text-surface-600 dark:text-surface-400">Automated scheduling</p>
                    </div>
                    <div class="bg-surface-50 dark:bg-surface-700 rounded-lg p-3">
                        <h5 class="font-medium text-surface-900 dark:text-surface-100 mb-1">Wippy Editor</h5>
                        <p class="text-surface-600 dark:text-surface-400">Direct code editing</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    function uiTutorialApp() {
        return {
            init() {
                console.log('UI Tutorial initialized');
            }
        }
    }
</script>
{{ end }}